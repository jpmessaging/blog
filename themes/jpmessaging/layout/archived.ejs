<article id="page-<%= page.slug %>" class="article article-type-page archived-page" itemscope itemtype="https://schema.org/WebPage">
  <div class="article-inner">
    <% if (page.title){ %>
      <header class="article-header-single">
        <h1 class="article-title" itemprop="name"><%= page.title %></h1>
      </header>
    <% } %>
    <div class="article-entry" itemprop="text" style="overflow-wrap: break-word">
      <%- page.content %>
    </div>
  </div>
</article>